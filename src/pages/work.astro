---
import Layout from '../layouts/Layout.astro';
import { projects } from '../data/projects.js';
---
<Layout title="Work — Amara Chen">
  <div class="wrap">
    <section class="hero">
      <h1>Work</h1>
      <p>A selection of projects, newest first.</p>
    </section>

    {projects.map((project) => (
      <figure class="plate">
        <a href={`/work/${project.slug}`}>
          <img src={project.image} alt={project.title} loading="lazy" />
        </a>
        <p class="plate-title">
          <a class="plate-link" href={`/work/${project.slug}`}>{project.title}</a>
        </p>
        <p class="plate-desc">{project.description}</p>
        <figcaption>
          <span>Plate {project.plate}</span>
          <span>{project.year}</span>
        </figcaption>
      </figure>
    ))}
  </div>
</Layout>
